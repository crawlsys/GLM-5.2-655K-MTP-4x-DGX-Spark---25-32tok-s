# GLM-5.2 QuantTrio Int4-Int8Mix — DCP4 / 655,360-token context + MTP k=3
# Source this before running serve.sh:  set -a; source glm52-qt-dcp4-655k.env; set +a
#
# EDIT markers below: substitute your image tag, model dir, and interface name.

IMAGE=vllm-zatz-dcp:probe                          # EDIT: your committed image tag
MODEL_DIR=/var/tmp/models/glm52-int4-int8mix       # EDIT: local weights path on every node
PROFILE=custom
SERVED_MODEL_NAME=glm-5.2
PORT=8210

# Parallelism / context
TP_SIZE=4
PP_SIZE=1
DCP_SIZE=4
DCP_COMM_BACKEND=ag_rs
DCP_KV_CACHE_INTERLEAVE_SIZE=1
MAX_MODEL_LEN=655360
MAX_NUM_SEQS=4
MAX_NUM_BATCHED_TOKENS=4096
MAX_CUDAGRAPH_CAPTURE_SIZE=32
GPU_MEMORY_UTILIZATION=0.88

# KV cache (fp8 DeepSeek-MLA, hard-capped ~9GB -> 657,664-token pool)
KV_CACHE_DTYPE=fp8_ds_mla
KV_CACHE_MEMORY_BYTES=9000000000

# Speculative decoding
ENABLE_MTP=1
NUM_SPECULATIVE_TOKENS=3

# Attention / MoE / quantization
ATTENTION_BACKEND=B12X_MLA_SPARSE
MOE_BACKEND=flashinfer_cutlass
QUANTIZATION=compressed-tensors

# Scheduling
LONG_PREFILL_TOKEN_THRESHOLD=2048
ASYNC_SCHEDULING=1

# Parsers (GLM-5.2 reasoning + tool calls)
REASONING_PARSER=glm45
TOOL_CALL_PARSER=glm47
ENABLE_AUTO_TOOL_CHOICE=1

# vLLM / B12X toggles
VLLM_USE_V2_MODEL_RUNNER=1
VLLM_USE_B12X_SPARSE_INDEXER=1
VLLM_DCP_GLOBAL_TOPK=1
VLLM_DCP_SHARD_DRAFT=1
VLLM_KZ_TRIM_AFTER_LOAD=1
VLLM_USE_B12X_MOE=0
VLLM_USE_B12X_FP8_GEMM=0
B12X_MOE_FORCE_A16=0
B12X_W4A16_TC_DECODE=0
B12X_DENSE_SPLITK_TURBO=0

# Fabric / NCCL
NCCL_IB_DISABLE=0
NCCL_SOCKET_IFNAME=enp1s0f0np0                      # EDIT: your RoCE interface name

# GB10 arch (sm_121a — NOT sm_120a)
CUTE_DSL_ARCH=sm_121a
TORCH_CUDA_ARCH_LIST=12.1a
VLLM_ALLOW_LONG_MAX_MODEL_LEN=1
NCCL_MAX_NCHANNELS=4
NCCL_MIN_NCHANNELS=4
CUDA_DEVICE_MAX_CONNECTIONS=32
