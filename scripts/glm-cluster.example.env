# Example cluster env for tonyd2wild's GLM-5.2 QuantTrio DCP4/655K recipe.
# Credit: tonyd2wild/GLM-5.2-655K-MTP-4x-DGX-Spark (and the ---25-32tok-s variant).
# Copy to glm-cluster.env, fill EDIT fields, then:
#   set -a; source scripts/glm-cluster.env; set +a
#   ./scripts/launch-ray.sh && ./scripts/serve.sh

# --- cluster topology ---
IMAGE=vllm-zatz-dcp:cutlass46          # after baking cutlass-dsl 4.6.0 (see EXTRA-NOTES.md)
MODEL_DIR=/path/to/GLM-5.2-Int4-Int8Mix  # local weights on EVERY node (never /var/tmp or tmpfs)
HEAD_IP=10.0.0.1                         # EDIT: fabric IP of head / rank0
WORKER_IPS="10.0.0.2 10.0.0.3 10.0.0.4" # EDIT: fabric IPs of the other three
HS_IFACE=enp1s0f1np1                     # EDIT: RoCE fabric interface name
NCCL_IB_HCA=rocep1s0f1                   # EDIT: RoCE HCA (use the rail that has the fabric IP)
SSH_KEY=$HOME/.ssh/id_ed25519
HEAD_NAME=glm-head
WORKER_NAME=glm-worker
RAY_PORT=26479
DROP_CACHES=0
NCCL_MAX_NCHANNELS=4
NCCL_MIN_NCHANNELS=4

# --- serve profile ---
PROFILE=custom
SERVED_MODEL_NAME=glm-5.2
PORT=8210
HOST=0.0.0.0
TP_SIZE=4
PP_SIZE=1
DCP_SIZE=4
DCP_COMM_BACKEND=ag_rs
DCP_KV_CACHE_INTERLEAVE_SIZE=1
MAX_MODEL_LEN=655360
MAX_NUM_SEQS=4
MAX_NUM_BATCHED_TOKENS=4096
MAX_CUDAGRAPH_CAPTURE_SIZE=32
GPU_MEMORY_UTILIZATION=0.88

# Hard-cap KV so vLLM SKIPS the profiling forward pass (the hang we hit on other recipes)
KV_CACHE_DTYPE=fp8_ds_mla
KV_CACHE_MEMORY_BYTES=9000000000

ENABLE_MTP=1
NUM_SPECULATIVE_TOKENS=3
ATTENTION_BACKEND=B12X_MLA_SPARSE
MOE_BACKEND=flashinfer_cutlass
QUANTIZATION=compressed-tensors
LOAD_FORMAT=auto
LONG_PREFILL_TOKEN_THRESHOLD=2048
ASYNC_SCHEDULING=1
ENABLE_PREFIX_CACHING=1
ENFORCE_EAGER=0

# REQUIRED for tool calling (agentic work dies without these)
REASONING_PARSER=glm45
TOOL_CALL_PARSER=glm47
ENABLE_AUTO_TOOL_CHOICE=1

# vLLM / b12x
VLLM_USE_B12X_SPARSE_INDEXER=1
VLLM_USE_V2_MODEL_RUNNER=1
VLLM_DCP_SHARD_DRAFT=1
CUTE_DSL_ARCH=sm_121a
CUDA_DEVICE_MAX_CONNECTIONS=32
NCCL_IB_GID_INDEX=3
NCCL_CUMEM_ENABLE=0
NCCL_NET=IB
